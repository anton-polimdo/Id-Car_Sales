clean_data.py
--------------
Membersihkan SEMUA berkas CSV mentah (*_raw.csv) di data/processed/
dan menstandardisasi kolom sesuai skema akhir:
    year (int), month (str, 3 huruf), category (str), brand (str),
    model (str), cc (int), fuel (str), assembly (str), sales_volume (int)

Input  : data/processed/*_raw.csv
Output : data/processed/*_clean.csv  (satu per file _raw.csv)
"""

import glob
import os
import pandas as pd

PROCESSED_DIR = "data/processed"

VALID_MONTHS = ["jan", "feb", "mar", "apr", "mei", "jun",
                "jul", "agu", "sep", "okt", "nov", "des"]


def clean_column_names(df: pd.DataFrame) -> pd.DataFrame:
    df.columns = (
        df.columns.str.strip()
        .str.lower()
        .str.replace(r"\s+", "_", regex=True)
    )
    return df


def clean_text_fields(df: pd.DataFrame) -> pd.DataFrame:
    text_cols = ["category", "brand", "model", "fuel", "assembly"]
    for col in text_cols:
        if col in df.columns:
            df[col] = (
                df[col]
                .astype(str)
                .str.replace(r"\n", " ", regex=True)
                .str.strip()
                .str.upper()
            )
    return df


def clean_numeric_fields(df: pd.DataFrame) -> pd.DataFrame:
    numeric_cols = ["cc", "sales_volume", "year"]
    for col in numeric_cols:
        if col in df.columns:
            df[col] = (
                df[col]
                .astype(str)
                .str.replace(r"[^\d\-]", "", regex=True)
                .replace("", "0")
                .astype(int)
            )
    return df


def normalize_month(df: pd.DataFrame) -> pd.DataFrame:
    if "month" in df.columns:
        df["month"] = df["month"].astype(str).str.strip().str.lower().str[:3]
        df = df[df["month"].isin(VALID_MONTHS)]
    return df


def clean_dataframe(df: pd.DataFrame) -> pd.DataFrame:
    df = clean_column_names(df)
    df = clean_text_fields(df)
    df = normalize_month(df)
    df = clean_numeric_fields(df)
    df = df.dropna(how="all")
    df = df.drop_duplicates()
    return df.reset_index(drop=True)


def main():
    raw_files = sorted(glob.glob(os.path.join(PROCESSED_DIR, "*_raw.csv")))
    if not raw_files:
        raise FileNotFoundError(f"Tidak ditemukan berkas *_raw.csv di: {PROCESSED_DIR}")

    for raw_path in raw_files:
        filename = os.path.basename(raw_path)
        output_path = raw_path.replace("_raw.csv", "_clean.csv")

        print(f"Membersihkan: {filename} ...")
        df = pd.read_csv(raw_path)
        df_clean = clean_dataframe(df)
        df_clean.to_csv(output_path, index=False)
        print(f"  -> Berhasil: {len(df_clean)} baris disimpan ke {output_path}")


if __name__ == "__main__":
    main()